{
  "name": "cleanclick",
  "version": "0.1.0",
  "description": "Browser extension that protects users from unwanted redirects, pop-under ads, fake download buttons, and malicious navigation tricks.",
  "private": true,
  "scripts": {
    "build": "webpack --mode production",
    "dev": "webpack --mode development --watch",
    "test": "jest --no-coverage --verbose",
    "test:unit": "jest tests/unit/ --no-coverage --verbose",
    "lint": "eslint src/ tests/ --ext .js",
    "package": "webpack --mode production && cd dist && zip -r ../cleanclick.zip ."
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "babel-jest": "^30.4.1",
    "jest": "^30.0.0",
    "jest-environment-jsdom": "^30.0.0",
    "webextension-polyfill": "^0.12.0"
  },
  "license": "MIT"
}
