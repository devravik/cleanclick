{
  "name": "cleanclick",
  "version": "0.1.0",
  "description": "Browser extension that protects users from unwanted redirects, pop-under ads, fake download buttons, and malicious navigation tricks.",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "webpack --mode production",
    "dev": "webpack --mode development --watch",
    "test": "jest",
    "lint": "eslint src/ tests/ --ext .js",
    "package": "webpack --mode production && cd dist && zip -r ../cleanclick.zip ."
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "jest": "^29.0.0",
    "webextension-polyfill": "^0.12.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4",
    "copy-webpack-plugin": "^12.0.0",
    "html-webpack-plugin": "^5.6.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFiles": ["./tests/setup.js"],
    "moduleNameMapper": {
      "^webextension-polyfill$": "./tests/__mocks__/browser-mock.js"
    }
  },
  "engines": {
    "firefox": ">=109.0"
  },
  "license": "MIT"
}
